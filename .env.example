# Caminho do arquivo de banco SQLite (criado automaticamente na primeira execucao)
DB_PATH=./ong_adocao.db

# Codigo secreto que transforma um cadastro em administrador.
# Quem digitar este codigo no cadastro vira admin; quem nao digitar vira usuario comum.
CODIGO_ACESSO_ONG=0000

# Pasta onde as fotos/documentos enviados serao gravados
STORAGE_DIR=./storage
